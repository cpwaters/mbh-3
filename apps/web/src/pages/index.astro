---
import Base from '../layouts/Base.astro';
---

<Base title="MyBackHaul — fill your empty return legs">
  <main class="landing">
    <h1>Fill your empty return legs.</h1>
    <p>
      MyBackHaul matches distributors' loads with drivers who have spare capacity on the way back — with a
      proof of delivery you can rely on, captured even where there's no signal.
    </p>
    <p>
      <a class="cta" href="/app">Open the driver app</a>
    </p>
    <p class="muted small">
      Built for UK haulage. Proof of delivery is recorded on the driver's device the moment it happens and
      delivered when signal returns.
    </p>
  </main>
</Base>
