{
  "name": "mbh3-root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "pnpm --filter @mbh/rules-tests test:rules",
    "test:contract": "firebase emulators:exec --only firestore --project demo-mbh --config firebase/firebase.json 'vitest run --config vitest.contract.config.ts'",
    "check:web": "pnpm --filter @mbh/web check",
    "build": "pnpm --filter @mbh/web build",
    "seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "firebase-tools": "^13.29.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
