{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["pnpm --filter @mbh/functions build"],
      "ignore": ["node_modules", ".git", "**/*.log", "src/**", "tsconfig.json", "**/*.map"]
    }
  ],
  "hosting": {
    "public": "apps/web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "dispatch" },
      { "source": "/health", "function": "dispatch" }
    ]
  },
  "emulators": {
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "auth": { "port": 9099 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": false },
    "singleProjectMode": true
  }
}
